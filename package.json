{
	"name": "life-manager",
	"version": "1.0.0",
	"description": "Comprehensive life manager",
	"scripts": {
		"client": "cd client && npm run dev",
		"server": "cd server && npm run dev",
		"migrate": "cd server && npm run migrate",
		"db:dev": "docker compose -f docker-compose.dev.yml up",
		"dev": "tsx export-env.ts",
		"dev:test": "cd server && npm run test && cd ../client && npm run test",
		"docker:up": "tsx up.ts",
		"docker:down": "tsx down.ts",
		"test:e2e": "cd client && npm run cypress:run",
		"test:e2e:ui": "cd client && npm run cypress:open"
	},
	"author": "threezinedine@gmail.com",
	"license": "ISC",
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"cypress": "^15.13.0"
	}
}
